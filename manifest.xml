<VersionOverrides
  xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
  xsi:type="VersionOverridesV1_1">

  <Requirements>
    <bt:Sets DefaultMinVersion="1.3">
      <bt:Set Name="Mailbox"/>
    </bt:Sets>
  </Requirements>

  <Hosts>
    <Host xsi:type="MailHost">
      <DesktopFormFactor>

        <FunctionFile resid="Commands.Url"/>

        <ExtensionPoint xsi:type="MessageReadCommandSurface">
          <OfficeTab id="TabDefault">
            <Group id="DealCloudGroup">
              <Label resid="DealCloudGroup.Label"/>

              <Control xsi:type="Button" id="OpenTaskPaneButton">
                <Label resid="TaskpaneButton.Label"/>
                <Supertip>
                  <Title resid="TaskpaneButton.Title"/>
                  <Description resid="TaskpaneButton.Description"/>
                </Supertip>
                <Icon>
                  <bt:Image size="16" resid="Icon.16"/>
                  <bt:Image size="32" resid="Icon.32"/>
                  <bt:Image size="80" resid="Icon.80"/>
                </Icon>
                <Action xsi:type="ShowTaskpane">
                  <SourceLocation resid="Taskpane.Url"/>
                </Action>
              </Control>

            </Group>
          </OfficeTab>
        </ExtensionPoint>

      </DesktopFormFactor>
    </Host>
  </Hosts>

  <Resources>
    <bt:Images>
      <bt:Image id="Icon.16" DefaultValue="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg"/>
      <bt:Image id="Icon.32" DefaultValue="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg"/>
      <bt:Image id="Icon.80" DefaultValue="https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg"/>
    </bt:Images>

    <bt:Urls>
      <bt:Url id="Commands.Url" DefaultValue="https://kyleaberger10-stack.github.io/dealcloud-outlook-intake-clean/taskpane.html"/>
      <bt:Url id="Taskpane.Url" DefaultValue="https://kyleaberger10-stack.github.io/dealcloud-outlook-intake-clean/taskpane.html"/>
    </bt:Urls>

    <bt:ShortStrings>
      <bt:String id="DealCloudGroup.Label" DefaultValue="DealCloud"/>
      <bt:String id="TaskpaneButton.Label" DefaultValue="DealCloud Intake"/>
      <bt:String id="TaskpaneButton.Title" DefaultValue="DealCloud Intake"/>
    </bt:ShortStrings>

    <bt:LongStrings>
      <bt:String id="TaskpaneButton.Description" DefaultValue="Review and intake this email."/>
    </bt:LongStrings>
  </Resources>

</VersionOverrides>
